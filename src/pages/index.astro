---
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from '../components/Search.astro';
import TopicCard from '../components/TopicCard.astro';
import Disclaimer from '../components/Disclaimer.astro';
import { getCollection } from 'astro:content';

const allTopics = await getCollection('topics', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

const featuredSlugs = [
  'f1-opt',
  'f1-cpt',
  'f1-stem-opt',
  'h1b-basics',
  'h1b-side-work',
  'h4-ead',
  'ead-overview',
  'working-without-authorization',
];

const featuredTopics = featuredSlugs
  .map(s => allTopics.find(t => t.slug === s))
  .filter(Boolean) as typeof allTopics;

const statusCards = [
  { status: 'f1', label: 'F-1 Student', description: 'International students at SEVP-certified schools' },
  { status: 'j1', label: 'J-1 Exchange Visitor', description: 'Exchange visitors in State Dept.-approved programs' },
  { status: 'h1b', label: 'H-1B Worker', description: 'Specialty occupation employees' },
  { status: 'h4', label: 'H-4 Dependent', description: 'Spouses and children of H-1B holders' },
  { status: 'l1', label: 'L-1 / L-2', description: 'Intracompany transferees and their families' },
  { status: 'gc', label: 'Green Card', description: 'Lawful permanent residents' },
];
---
<BaseLayout title="WorkAuthUS" description="Plain-language answers to US work authorization questions, with links to the actual law.">
  <!-- Hero -->
  <section class="bg-blue-800 dark:bg-blue-950 text-white py-12 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-3xl sm:text-4xl font-bold mb-3 leading-tight">US Work Authorization, Explained</h1>
      <p class="text-blue-100 text-lg mb-8 leading-relaxed">
        Plain-language answers to common questions non-citizens have about working in the US, with direct links to the actual law.
      </p>
      <div class="max-w-xl mx-auto bg-white rounded">
        <Search />
      </div>
      <p class="mt-3 text-blue-200 text-sm">Search topics, statuses, or regulations &mdash; or browse below</p>
    </div>
  </section>

  <!-- Browse by status -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-slate-100 mb-6">Browse by immigration status</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {statusCards.map(card => (
        <a
          href={`/status/${card.status}`}
          class="block border border-gray-200 dark:border-slate-700 rounded p-4 hover:border-blue-400 dark:hover:border-blue-600 hover:bg-blue-50 dark:hover:bg-blue-900/20 transition-colors group"
        >
          <h3 class="font-semibold text-gray-900 dark:text-slate-100 group-hover:text-blue-800 dark:group-hover:text-blue-300 mb-1">
            {card.label}
          </h3>
          <p class="text-sm text-gray-600 dark:text-slate-400">{card.description}</p>
        </a>
      ))}
    </div>
    <p class="mt-4 text-sm text-gray-500 dark:text-slate-500">
      <a href="/topics" class="text-blue-700 dark:text-blue-400 underline hover:text-blue-900 dark:hover:text-blue-300">
        See all topics and statuses →
      </a>
    </p>
  </section>

  <!-- Most common questions -->
  <section class="bg-gray-50 dark:bg-slate-900 py-12 px-4">
    <div class="max-w-6xl mx-auto sm:px-6">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-slate-100 mb-6">Most common questions</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {featuredTopics.map(topic => (
          <TopicCard topic={topic} />
        ))}
      </div>
    </div>
  </section>

  <!-- What this site is -->
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-slate-100 mb-4">What this site is — and isn't</h2>
    <div class="prose text-gray-700 dark:text-slate-300">
      <p>
        <strong>WorkAuthUS</strong> is a free, open-source reference site. Every page links directly to a primary source — a federal statute, regulation, or official agency page — so you can read the law yourself, not just our summary.
      </p>
      <p>
        <strong>This site does not provide legal advice.</strong> Immigration law is complex and fact-specific. A rule that applies in one situation may not apply in yours. Nothing on this site creates an attorney-client relationship.
      </p>
      <p>
        If you need advice for your specific situation, please <a href="/find-legal-help">find a licensed attorney or accredited representative</a>. Many provide free or low-cost consultations.
      </p>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 pb-8">
    <Disclaimer />
  </div>
</BaseLayout>
