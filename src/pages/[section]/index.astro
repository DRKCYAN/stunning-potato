---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SECTIONS, SECTION_IDS } from '../../data/sections';

export async function getStaticPaths() {
  return SECTION_IDS.map(section => ({
    params: { section },
    props: { meta: SECTIONS[section] },
  }));
}

const { section } = Astro.params;
const { meta } = Astro.props;

const allQuestions = await getCollection('questions');
const sectionQuestions = allQuestions
  .filter(q => q.data.section === section && !q.data.draft)
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

function questionSlug(slug: string) {
  return slug.split('/').slice(1).join('/');
}

// Statuses present in this section's questions (used for filter chips)
const allStatuses = [...new Set(sectionQuestions.flatMap(q => q.data.statuses ?? []))].sort();
const hasFilter = allStatuses.length > 0;
---

<BaseLayout title={`${meta.label} — KnowYourStatus`} description={meta.description}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: meta.label },
    ]} />

    <div class="mt-6 rounded border border-amber-300 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-700 px-4 py-3 text-sm text-amber-800 dark:text-amber-300">
      <strong>This section is under development.</strong> Questions listed below do not have answers yet. Content with primary source links will be added soon.
    </div>

    <h1 class="mt-6 text-3xl font-bold text-gray-900 dark:text-slate-100">{meta.label}</h1>
    <p class="mt-3 text-gray-600 dark:text-slate-400 leading-relaxed">{meta.description}</p>

    {hasFilter && (
      <div
        id="status-filter"
        class="mt-6 flex flex-wrap gap-2"
        role="group"
        aria-label="Filter questions by immigration status"
      >
        <button class="filter-chip" data-status="all" data-active="true">All</button>
        {allStatuses.map(s => (
          <button class="filter-chip" data-status={s} data-active="false">
            {s.toUpperCase()}
          </button>
        ))}
      </div>
    )}

    <section class="mt-6">
      {sectionQuestions.length === 0 ? (
        <p class="text-gray-500 dark:text-slate-500 italic text-sm">
          No questions have been added to this section yet.
        </p>
      ) : (
        <ul
          id="question-list"
          class="divide-y divide-gray-100 dark:divide-slate-800 border border-gray-200 dark:border-slate-700 rounded overflow-hidden"
        >
          {sectionQuestions.map(q => (
            <li data-statuses={(q.data.statuses ?? []).join(',') || 'all'}>
              <a
                href={`/${section}/${questionSlug(q.slug)}`}
                class="flex items-center justify-between px-4 py-3 hover:bg-blue-50 dark:hover:bg-blue-900/20 group transition-colors"
              >
                <span class="text-gray-800 dark:text-slate-200 group-hover:text-blue-700 dark:group-hover:text-blue-300 text-sm leading-snug">
                  {q.data.title}
                </span>
                <span class="ml-4 flex-shrink-0 text-xs bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-400 rounded px-2 py-0.5 whitespace-nowrap">
                  Coming soon
                </span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>

    <div class="mt-10">
      <Disclaimer />
    </div>
  </div>
</BaseLayout>

<script>
  const chips = document.querySelectorAll<HTMLElement>('#status-filter .filter-chip');
  const items = document.querySelectorAll<HTMLElement>('#question-list li');

  chips.forEach(chip => {
    chip.addEventListener('click', () => {
      const status = chip.dataset.status!;

      chips.forEach(c => {
        c.dataset.active = c === chip ? 'true' : 'false';
      });

      items.forEach(item => {
        const statuses = (item.dataset.statuses ?? '').split(',');
        const visible = status === 'all' || statuses.includes('all') || statuses.includes(status);
        item.style.display = visible ? '' : 'none';
      });
    });
  });
</script>
