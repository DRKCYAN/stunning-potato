---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SECTIONS } from '../../data/sections';

export async function getStaticPaths() {
  const questions = await getCollection('questions');
  return questions
    .filter(q => !q.data.draft)
    .map(q => {
      const parts = q.slug.split('/');
      return {
        params: { section: parts[0], slug: parts.slice(1).join('/') },
        props: { question: q },
      };
    });
}

const { section } = Astro.params;
const { question } = Astro.props;
const meta = SECTIONS[section as keyof typeof SECTIONS];
const { Content } = await question.render();
const { comingSoon, primarySources, lastVerified, verifiedBy } = question.data;
---

<BaseLayout
  title={`${question.data.title} — WorkAuthUS`}
  description={`Learn about: ${question.data.title}`}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: meta?.label ?? section, href: `/${section}` },
      { label: question.data.title },
    ]} />

    <h1 class="mt-6 text-3xl font-bold text-gray-900 dark:text-slate-100 leading-tight">
      {question.data.title}
    </h1>

    {comingSoon ? (
      <div class="mt-6 rounded border border-blue-300 bg-blue-50 dark:bg-blue-900/20 dark:border-blue-700 px-5 py-4">
        <p class="font-semibold text-blue-800 dark:text-blue-300">This page is under development</p>
        <p class="mt-1 text-sm text-blue-700 dark:text-blue-400">
          Content with primary source links will be added soon.{' '}
          <a
            href="https://github.com/DRKCYAN/stunning-potato/issues"
            class="underline hover:text-blue-900 dark:hover:text-blue-200"
            target="_blank"
            rel="noopener noreferrer"
          >
            Contribute on GitHub
          </a>.
        </p>
      </div>
    ) : (
      <>
        <div class="mt-8 prose prose-gray dark:prose-invert max-w-none text-gray-700 dark:text-slate-300">
          <Content />
        </div>

        {primarySources && primarySources.length > 0 && (
          <div class="mt-10 border-t border-gray-200 dark:border-slate-700 pt-6">
            <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-3">
              Primary Sources
            </h2>
            <ul class="space-y-2">
              {primarySources.map((src: { citation: string; title: string; url: string }) => (
                <li class="text-sm text-gray-600 dark:text-slate-400">
                  <span class="font-medium">{src.citation}</span> —{' '}
                  <a
                    href={src.url}
                    class="text-blue-600 dark:text-blue-400 hover:underline"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {src.title}
                  </a>
                </li>
              ))}
            </ul>
            {lastVerified && (
              <p class="mt-3 text-xs text-gray-400 dark:text-slate-500">
                Last verified: {new Date(lastVerified).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                {verifiedBy ? ` · ${verifiedBy}` : ''}
              </p>
            )}
          </div>
        )}
      </>
    )}

    <div class="mt-10">
      <Disclaimer />
    </div>
  </div>
</BaseLayout>
