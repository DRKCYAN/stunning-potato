---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { SECTIONS } from '../../data/sections';

export async function getStaticPaths() {
  const questions = await getCollection('questions');
  return questions
    .filter(q => !q.data.draft)
    .map(q => {
      const parts = q.slug.split('/');
      return {
        params: { section: parts[0], slug: parts.slice(1).join('/') },
        props: { question: q },
      };
    });
}

const { section } = Astro.params;
const { question } = Astro.props;
const meta = SECTIONS[section as keyof typeof SECTIONS];
---

<BaseLayout
  title={`${question.data.title} — WorkAuthUS`}
  description={`Learn about: ${question.data.title}`}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: meta?.label ?? section, href: `/${section}` },
      { label: question.data.title },
    ]} />

    <h1 class="mt-6 text-3xl font-bold text-gray-900 dark:text-slate-100 leading-tight">
      {question.data.title}
    </h1>

    <div class="mt-6 rounded border border-blue-300 bg-blue-50 dark:bg-blue-900/20 dark:border-blue-700 px-5 py-4">
      <p class="font-semibold text-blue-800 dark:text-blue-300">This page is under development</p>
      <p class="mt-1 text-sm text-blue-700 dark:text-blue-400">
        Content with primary source links will be added soon.
        <a
          href="https://github.com/DRKCYAN/stunning-potato/issues"
          class="underline hover:text-blue-900 dark:hover:text-blue-200"
          target="_blank"
          rel="noopener noreferrer"
        >
          Contribute on GitHub
        </a>.
      </p>
    </div>

    <!-- Answer content will go here -->
    <div class="mt-8 prose dark:prose-invert text-gray-700 dark:text-slate-300 min-h-[8rem]">
    </div>

    <div class="mt-10">
      <Disclaimer />
    </div>
  </div>
</BaseLayout>
