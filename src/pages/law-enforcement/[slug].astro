---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Disclaimer from '../../components/Disclaimer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { fetchWiki, type WikiArticle } from '../../lib/wikipedia';

// ── Topic definitions ────────────────────────────────────────────────────────

interface GovLink {
  label: string;
  url: string;
}

interface TopicConfig {
  title: string;
  wikiArticles: string[];
  sectionsToShow: string[];
  govLinks: GovLink[];
  intro: string;
}

const TOPICS: Record<string, TopicConfig> = {
  'ice-vs-local-police': {
    title: "ICE vs. local police: what's the difference?",
    intro:
      "U.S. Immigration and Customs Enforcement (ICE) is a federal agency. Local police are state or municipal law enforcement. They have different legal authority, different missions, and different rules about when they can ask about immigration status.",
    wikiArticles: [
      'U.S. Immigration and Customs Enforcement',
      '287(g) program',
      'Sanctuary city',
    ],
    sectionsToShow: [
      'Mission', 'Organization', 'Enforcement', 'Criticism', 'Overview',
      'History', 'Definition', 'Legal authority', 'Background',
    ],
    govLinks: [
      { label: 'ICE — Official Site', url: 'https://www.ice.gov' },
      { label: 'DHS — Immigration Enforcement', url: 'https://www.dhs.gov/topic/immigration-enforcement' },
      { label: 'ACLU — Immigrants\' Rights', url: 'https://www.aclu.org/know-your-rights/immigrants-rights' },
      { label: 'DOJ — Civil Rights Division', url: 'https://www.justice.gov/crt' },
    ],
  },
  'rights-during-traffic-stop': {
    title: 'Your rights during a traffic stop',
    intro:
      "Whether you are a citizen, visa holder, or undocumented, you have constitutional rights during a traffic stop. Knowing them can protect you regardless of your immigration status.",
    wikiArticles: [
      'Traffic stop',
      'Fourth Amendment to the United States Constitution',
      'Terry stop',
    ],
    sectionsToShow: [
      'Rights', 'Procedure', 'Overview', 'History', 'Background',
      'Searches and seizures', 'Legal standard', 'Reasonableness', 'Stop and frisk',
    ],
    govLinks: [
      { label: 'ACLU — Your Rights During a Traffic Stop', url: 'https://www.aclu.org/know-your-rights/stops-and-arrests' },
      { label: 'DOJ — Civil Rights Division', url: 'https://www.justice.gov/crt' },
      { label: 'USCIS — Know Your Rights', url: 'https://www.uscis.gov/forms/civil-rights/know-your-rights' },
    ],
  },
};

// ── Route handling ───────────────────────────────────────────────────────────

const { slug } = Astro.params;
const topic = slug ? TOPICS[slug] : undefined;

if (!topic) {
  return Astro.redirect('/404');
}

// ── Fetch Wikipedia articles ─────────────────────────────────────────────────

let articles: WikiArticle[] = [];
let fetchError = false;
let fetchedAt = '';

try {
  articles = await Promise.all(topic.wikiArticles.map(fetchWiki));
  fetchedAt = new Date().toUTCString();
} catch (err) {
  console.error('Wikipedia fetch error:', err);
  fetchError = true;
}

const showSet = new Set(topic.sectionsToShow.map(s => s.toLowerCase()));

function relevantSections(article: WikiArticle) {
  return article.sections.filter(s => showSet.has(s.title.toLowerCase()));
}
---

<BaseLayout
  title={`${topic.title} — KnowYourStatus`}
  description={topic.intro}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-8">
    <Breadcrumbs items={[
      { label: 'Home', href: '/' },
      { label: "Law Enforcement", href: '/law-enforcement' },
      { label: topic.title },
    ]} />

    <h1 class="mt-6 text-3xl font-bold text-gray-900 dark:text-slate-100 leading-tight">
      {topic.title}
    </h1>

    <!-- Live data badge -->
    <div class="mt-3 flex items-center gap-2">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-700 px-3 py-1 text-xs font-medium text-green-700 dark:text-green-400">
        <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
        Live — fetched from Wikipedia
      </span>
      {fetchedAt && (
        <span class="text-xs text-gray-400 dark:text-slate-500">{fetchedAt}</span>
      )}
    </div>

    <!-- Intro -->
    <p class="mt-6 text-lg text-gray-700 dark:text-slate-300 leading-relaxed">
      {topic.intro}
    </p>

    {fetchError ? (
      <div class="mt-8 rounded border border-amber-300 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-700 px-5 py-4">
        <p class="font-semibold text-amber-800 dark:text-amber-300">Could not load live content</p>
        <p class="mt-1 text-sm text-amber-700 dark:text-amber-400">
          Wikipedia could not be reached right now. Try refreshing the page, or visit the sources directly below.
        </p>
      </div>
    ) : (
      <div class="mt-10 space-y-12">
        {articles.map((article) => {
          const sections = relevantSections(article);
          return (
            <div>
              <!-- Article header -->
              <div class="flex items-baseline justify-between gap-4 border-b border-gray-200 dark:border-slate-700 pb-2 mb-5">
                <h2 class="text-xl font-bold text-gray-900 dark:text-slate-100">
                  {article.title}
                </h2>
                <a
                  href={article.url}
                  class="shrink-0 text-xs text-blue-600 dark:text-blue-400 hover:underline"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Wikipedia ↗
                </a>
              </div>

              <!-- Intro paragraph -->
              <p class="text-gray-700 dark:text-slate-300 leading-relaxed whitespace-pre-line">
                {article.intro}
              </p>

              <!-- Relevant sections -->
              {sections.map((sec) => (
                <div class="mt-6">
                  <h3 class="text-base font-semibold text-gray-800 dark:text-slate-200 mb-2">
                    {sec.title}
                  </h3>
                  <p class="text-gray-700 dark:text-slate-300 leading-relaxed whitespace-pre-line">
                    {sec.content}
                  </p>
                </div>
              ))}
            </div>
          );
        })}
      </div>
    )}

    <!-- Government sources -->
    <div class="mt-12 border-t border-gray-200 dark:border-slate-700 pt-6">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-gray-500 dark:text-slate-400 mb-3">
        Official & Legal Sources
      </h2>
      <ul class="space-y-2">
        {topic.govLinks.map((link) => (
          <li>
            <a
              href={link.url}
              class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              {link.label} ↗
            </a>
          </li>
        ))}
        {articles.map((article) => (
          <li>
            <a
              href={article.url}
              class="text-sm text-blue-600 dark:text-blue-400 hover:underline"
              target="_blank"
              rel="noopener noreferrer"
            >
              Wikipedia — {article.title} ↗
            </a>
          </li>
        ))}
      </ul>
      <p class="mt-4 text-xs text-gray-400 dark:text-slate-500">
        Wikipedia content is used under the{' '}
        <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="underline" target="_blank" rel="noopener noreferrer">
          CC BY-SA 4.0 license
        </a>.
        Content is fetched live and may differ from the current Wikipedia article.
      </p>
    </div>

    <div class="mt-10">
      <Disclaimer />
    </div>
  </div>
</BaseLayout>
