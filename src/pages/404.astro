---
import BaseLayout from '../layouts/BaseLayout.astro';
import Search from '../components/Search.astro';
---
<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-16 text-center">
    <p class="text-6xl font-bold text-gray-200 dark:text-slate-700 mb-4" aria-hidden="true">404</p>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-slate-100 mb-3">Page not found</h1>
    <p class="text-gray-600 dark:text-slate-400 mb-8 leading-relaxed max-w-md mx-auto">
      We couldn't find that page. Try searching for your question, or browse all topics.
    </p>
    <div class="max-w-md mx-auto mb-8">
      <Search />
    </div>
    <a
      href="/topics"
      class="inline-block bg-blue-700 hover:bg-blue-800 text-white font-medium px-6 py-2.5 rounded transition-colors"
    >
      Browse all topics
    </a>
  </div>
</BaseLayout>
