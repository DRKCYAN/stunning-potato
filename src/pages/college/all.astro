---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('college', ({ data }) =>
  import.meta.env.PROD ? !data.draft : true
);

const sorted = [...entries].sort((a, b) =>
  a.data.visa.localeCompare(b.data.visa) || a.data.state.localeCompare(b.data.state)
);

const statusColor = (val: string) => {
  if (val === 'yes') return 'bg-green-50 text-green-800 dark:bg-green-900/30 dark:text-green-300';
  if (val === 'no') return 'bg-red-50 text-red-800 dark:bg-red-900/30 dark:text-red-300';
  return 'bg-amber-50 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300';
};
---
<BaseLayout title="All College Application Pages" description="Browse all visa + state combinations for college tuition and application eligibility.">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
    <nav aria-label="Breadcrumb" class="text-sm text-gray-500 dark:text-slate-500 mb-4">
      <a href="/" class="underline hover:text-blue-700 dark:hover:text-blue-400">Home</a>
      {' › '}
      <a href="/college" class="underline hover:text-blue-700 dark:hover:text-blue-400">College Applications</a>
      {' › '}
      <span aria-current="page" class="text-gray-700 dark:text-slate-300">All pages</span>
    </nav>

    <h1 class="text-3xl font-bold text-gray-900 dark:text-slate-100 mb-2">All College Application Pages</h1>
    <p class="text-gray-500 dark:text-slate-500 mb-8 text-sm">{sorted.length} pages available</p>

    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b-2 border-gray-200 dark:border-slate-700 text-left">
            <th class="py-2 pr-4 font-semibold text-gray-700 dark:text-slate-300">Visa</th>
            <th class="py-2 pr-4 font-semibold text-gray-700 dark:text-slate-300">State</th>
            <th class="py-2 pr-4 font-semibold text-gray-700 dark:text-slate-300">In-State Tuition</th>
            <th class="py-2 pr-4 font-semibold text-gray-700 dark:text-slate-300">Public Universities</th>
            <th class="py-2 pr-4 font-semibold text-gray-700 dark:text-slate-300">State Financial Aid</th>
          </tr>
        </thead>
        <tbody>
          {sorted.map(e => (
            <tr class="border-b border-gray-100 dark:border-slate-800 hover:bg-gray-50 dark:hover:bg-slate-900">
              <td class="py-2.5 pr-4">
                <a href={`/college/${e.data.visa}/${e.data.stateCode}`} class="text-blue-700 dark:text-blue-400 underline hover:text-blue-900 dark:hover:text-blue-300 font-medium">
                  {e.data.visaLabel}
                </a>
              </td>
              <td class="py-2.5 pr-4 text-gray-700 dark:text-slate-300">{e.data.state}</td>
              <td class="py-2.5 pr-4">
                <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium capitalize ${statusColor(e.data.inStateTuitionEligible)}`}>
                  {e.data.inStateTuitionEligible}
                </span>
              </td>
              <td class="py-2.5 pr-4">
                <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium capitalize ${statusColor(e.data.canApplyToPublicUniversities)}`}>
                  {e.data.canApplyToPublicUniversities}
                </span>
              </td>
              <td class="py-2.5">
                <span class={`inline-block px-2 py-0.5 rounded text-xs font-medium capitalize ${statusColor(e.data.canReceiveStateFinancialAid)}`}>
                  {e.data.canReceiveStateFinancialAid}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</BaseLayout>
