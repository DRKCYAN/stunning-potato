---
export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---
<nav aria-label="Breadcrumb" class="text-sm text-gray-500 dark:text-slate-500">
  <ol class="flex flex-wrap items-center gap-1" itemscope itemtype="https://schema.org/BreadcrumbList">
    {items.map((item, i) => (
      <li class="flex items-center gap-1" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        {item.href ? (
          <a href={item.href} itemprop="item" class="hover:text-blue-700 dark:hover:text-blue-400 underline">
            <span itemprop="name">{item.label}</span>
          </a>
        ) : (
          <span itemprop="name" class="text-gray-700 dark:text-slate-300" aria-current="page">{item.label}</span>
        )}
        <meta itemprop="position" content={String(i + 1)} />
        {i < items.length - 1 && (
          <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" class="w-3 h-3 text-gray-400 flex-shrink-0">
            <path fill-rule="evenodd" d="M6.22 4.22a.75.75 0 0 1 1.06 0l3.25 3.25a.75.75 0 0 1 0 1.06l-3.25 3.25a.75.75 0 0 1-1.06-1.06L9.19 8 6.22 5.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
          </svg>
        )}
      </li>
    ))}
  </ol>
</nav>
