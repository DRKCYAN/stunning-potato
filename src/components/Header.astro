---
const navLinks = [
  { href: '/topics', label: 'Browse Topics' },
  { href: '/find-legal-help', label: 'Find Legal Help' },
  { href: '/about', label: 'About' },
];

const current = Astro.url.pathname;
---
<header class="border-b border-gray-200 bg-white dark:bg-slate-900 dark:border-slate-700">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
    <a href="/" class="font-bold text-lg text-blue-800 dark:text-blue-400 hover:text-blue-900 dark:hover:text-blue-300 no-underline">
      WorkAuthUS
    </a>
    <nav aria-label="Main navigation">
      <ul class="flex items-center gap-1 sm:gap-2 text-sm">
        {navLinks.map(link => (
          <li>
            <a
              href={link.href}
              class={[
                'px-3 py-1.5 rounded transition-colors',
                current.startsWith(link.href)
                  ? 'bg-blue-50 text-blue-800 font-medium dark:bg-blue-900/30 dark:text-blue-300'
                  : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100 dark:text-slate-400 dark:hover:text-slate-200 dark:hover:bg-slate-800',
              ].join(' ')}
              aria-current={current.startsWith(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
